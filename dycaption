#!/bin/bash
# dycaption - 抖音文案提取 CLI
# 零依赖，仅需 curl（macOS/Linux 自带）

set -e

API_URL="${DY_CAPTION_API_URL:-https://api.dytext.cn}"
API_KEY="${DY_CAPTION_API_KEY:-}"
CONFIG_FILE="${HOME}/.dycaption"

SUPABASE_URL="${DY_CAPTION_SUPABASE_URL:-https://wcedjbnfdlfnomzwtwlq.supabase.co}"
SUPABASE_ANON_KEY="${DY_CAPTION_SUPABASE_ANON_KEY:-}"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

error() { echo -e "${RED}错误: $1${NC}" >&2; exit 1; }
success() { echo -e "${GREEN}$1${NC}"; }
info() { echo -e "$1"; }
prompt() { echo -e "${CYAN}$1${NC}" >&2; }

json_str() {
  echo "$1" | grep -o "\"$2\":\"[^\"]*\"" | head -1 | sed 's/.*:"//;s/"$//'
}

json_num() {
  echo "$1" | grep -o "\"$2\":[0-9.]*" | head -1 | sed 's/.*://'
}

load_config() {
  if [ -z "$API_KEY" ] && [ -f "$CONFIG_FILE" ]; then
    local key
    key=$(grep "^DY_CAPTION_API_KEY=" "$CONFIG_FILE" 2>/dev/null | head -1 | sed 's/DY_CAPTION_API_KEY=//')
    if [ -n "$key" ]; then
      API_KEY="$key"
    fi
  fi
}

save_config() {
  local key="$1"
  cat > "$CONFIG_FILE" << EOF2
DY_CAPTION_API_KEY=${key}
EOF2
  chmod 600 "$CONFIG_FILE"
}

check_config() {
  load_config
  if [ -z "$API_KEY" ]; then
    error "未配置 API Key\n\n  运行 ${BOLD}dycaption setup${NC} 注册账号并自动配置\n  或设置环境变量: export DY_CAPTION_API_KEY=\"dy_xxxxx\""
  fi
}

require_supabase_config() {
  if [ -z "$SUPABASE_URL" ] || [ -z "$SUPABASE_ANON_KEY" ]; then
    error "注册/登录需要 Supabase 公共配置\n\n  export DY_CAPTION_SUPABASE_URL=\"https://wcedjbnfdlfnomzwtwlq.supabase.co\"\n  export DY_CAPTION_SUPABASE_ANON_KEY=\"your_supabase_anon_key\""
  fi
}

api_call() {
  local method="$1"
  local path="$2"
  local body="$3"

  local args=(-s -X "$method" \
    -H "Content-Type: application/json" \
    -H "X-API-Key: $API_KEY")

  if [ -n "$body" ]; then
    args+=(-d "$body")
  fi

  local resp
  resp=$(curl "${args[@]}" "${API_URL}${path}" 2>&1) || error "请求失败，请检查网络连接"

  local err_msg
  err_msg=$(json_str "$resp" "error")
  if [ -n "$err_msg" ]; then
    error "$err_msg"
  fi

  echo "$resp"
}

fetch_api_key() {
  local jwt="$1"
  local resp
  resp=$(curl -s "${SUPABASE_URL}/rest/v1/profiles?select=api_key" \
    -H "apikey: ${SUPABASE_ANON_KEY}" \
    -H "Authorization: Bearer ${jwt}")

  local api_key
  api_key=$(json_str "$resp" "api_key")
  echo "$api_key"
}

do_register() {
  local email="$1"
  local password="$2"

  require_supabase_config

  info "📧 注册中..."
  local resp
  resp=$(curl -s -X POST "${SUPABASE_URL}/auth/v1/signup" \
    -H "apikey: ${SUPABASE_ANON_KEY}" \
    -H "Content-Type: application/json" \
    -d "{\"email\":\"${email}\",\"password\":\"${password}\"}")

  local err_msg
  err_msg=$(json_str "$resp" "msg")
  if [ -n "$err_msg" ]; then
    error "注册失败: ${err_msg}"
  fi

  local access_token
  access_token=$(json_str "$resp" "access_token")
  if [ -z "$access_token" ]; then
    success "✅ 注册成功！请查收邮箱确认邮件"
    info ""
    info "   确认邮箱后运行: ${BOLD}dycaption login${NC}"
    exit 0
  fi

  local api_key
  api_key=$(fetch_api_key "$access_token")
  if [ -z "$api_key" ]; then
    error "注册成功但未获取到 API Key，请稍后使用 ${BOLD}dycaption login${NC} 登录"
  fi

  save_config "$api_key"
  API_KEY="$api_key"

  success "✅ 注册成功！"
  success "✅ API Key 已保存到 ${CONFIG_FILE}"
}

do_login() {
  local email="$1"
  local password="$2"

  require_supabase_config

  info "🔑 登录中..."
  local resp
  resp=$(curl -s -X POST "${SUPABASE_URL}/auth/v1/token?grant_type=password" \
    -H "apikey: ${SUPABASE_ANON_KEY}" \
    -H "Content-Type: application/json" \
    -d "{\"email\":\"${email}\",\"password\":\"${password}\"}")

  local err_msg
  err_msg=$(json_str "$resp" "msg")
  if [ -n "$err_msg" ]; then
    error "登录失败: ${err_msg}"
  fi

  local access_token
  access_token=$(json_str "$resp" "access_token")
  if [ -z "$access_token" ]; then
    error "登录失败，未获取到访问令牌"
  fi

  local api_key
  api_key=$(fetch_api_key "$access_token")
  if [ -z "$api_key" ]; then
    error "登录成功但未获取到 API Key"
  fi

  save_config "$api_key"
  API_KEY="$api_key"

  success "✅ 登录成功！"
  success "✅ API Key 已保存到 ${CONFIG_FILE}"
}

cmd_register() {
  prompt "📧 请输入邮箱: "
  read -r email
  if [ -z "$email" ]; then
    error "邮箱不能为空"
  fi

  prompt "🔒 请输入密码 (至少6位): "
  read -rs password
  echo ""
  if [ -z "$password" ] || [ ${#password} -lt 6 ]; then
    error "密码不能少于6位"
  fi

  prompt "🔒 请确认密码: "
  read -rs password2
  echo ""
  if [ "$password" != "$password2" ]; then
    error "两次密码不一致"
  fi

  do_register "$email" "$password"
  if [ -n "$API_KEY" ]; then
    echo ""
    get_balance
  fi
}

cmd_login() {
  prompt "📧 请输入邮箱: "
  read -r email
  if [ -z "$email" ]; then
    error "邮箱不能为空"
  fi

  prompt "🔒 请输入密码: "
  read -rs password
  echo ""
  if [ -z "$password" ]; then
    error "密码不能为空"
  fi

  do_login "$email" "$password"
  echo ""
  get_balance
}

cmd_setup() {
  echo -e "${BOLD}dy-caption CLI - 账号配置${NC}"
  echo ""
  echo "  1) 注册新账号"
  echo "  2) 已有账号，直接登录"
  echo ""
  prompt "请选择 [1/2]: "
  read -r choice

  case "$choice" in
    1)
      cmd_register
      ;;
    2)
      cmd_login
      ;;
    *)
      error "无效选择"
      ;;
  esac
}

transcribe_status() {
  local task_id="$1"
  api_call "GET" "/api/v1/transcribe/${task_id}" ""
}

cmd_transcribe() {
  local input="$1"
  local language="${2:-zh-CN}"

  [ -z "$input" ] && error "请提供抖音分享链接或文案\n  用法: dycaption transcribe <链接或分享文案> [语言]"

  check_config

  info "📝 提交转写任务: ${YELLOW}${input:0:60}${NC}"
  info "   语言: ${language}"
  info "   提交中..."

  local body
  body=$(printf '{"input":"%s","language":"%s"}' "$(echo "$input" | sed 's/"/\\"/g')" "$language")

  local resp
  resp=$(api_call "POST" "/api/v1/transcribe" "$body")

  local task_id
  task_id=$(json_str "$resp" "taskId")
  [ -z "$task_id" ] && error "创建任务失败，未返回 taskId"

  info "   任务 ID: $task_id"

  local timeout=300
  local interval=3
  local elapsed=0

  while [ $elapsed -lt $timeout ]; do
    sleep $interval
    elapsed=$((elapsed + interval))

    local poll
    poll=$(transcribe_status "$task_id")

    local status
    status=$(json_str "$poll" "status")

    if [ "$status" = "completed" ]; then
      echo ""
      success "✅ 转写完成！"
      local author video_desc duration credit_cost result
      author=$(json_str "$poll" "author")
      video_desc=$(json_str "$poll" "videoDesc")
      duration=$(json_num "$poll" "duration")
      credit_cost=$(json_num "$poll" "creditCost")
      result=$(json_str "$poll" "resultText")

      [ -n "$author" ] && info "   作者: $author"
      [ -n "$video_desc" ] && info "   视频文案: $video_desc"
      [ -n "$duration" ] && info "   时长: ${duration} 分钟"
      [ -n "$credit_cost" ] && info "   消耗积分: ${credit_cost}"

      echo ""
      info "${BOLD}提取文案:${NC}"
      [ -n "$result" ] && echo "$result" || echo "(空)"
      return
    fi

    if [ "$status" = "failed" ]; then
      local err_msg
      err_msg=$(json_str "$poll" "errorMessage")
      error "转写失败: ${err_msg:-未知错误}"
    fi

    info "   等待中... (${elapsed}s)"
  done

  error "转写超时（${timeout}s），任务 ID: ${task_id}"
}

cmd_status() {
  local task_id="$1"
  [ -z "$task_id" ] && error "请提供 taskId\n  用法: dycaption status <taskId>"

  check_config

  local task
  task=$(transcribe_status "$task_id")

  success "📌 任务状态"
  info "   taskId: $(json_str "$task" "taskId")"
  info "   status: $(json_str "$task" "status")"

  local duration credit_cost author video_desc err_msg result
  duration=$(json_num "$task" "duration")
  credit_cost=$(json_num "$task" "creditCost")
  author=$(json_str "$task" "author")
  video_desc=$(json_str "$task" "videoDesc")
  err_msg=$(json_str "$task" "errorMessage")
  result=$(json_str "$task" "resultText")

  [ -n "$duration" ] && info "   duration: ${duration} 分钟"
  [ -n "$credit_cost" ] && info "   creditCost: ${credit_cost}"
  [ -n "$author" ] && info "   author: ${author}"
  [ -n "$video_desc" ] && info "   videoDesc: ${video_desc}"
  [ -n "$err_msg" ] && info "   error: ${err_msg}"
  if [ -n "$result" ]; then
    echo ""
    info "${BOLD}resultText:${NC}"
    echo "$result"
  fi
}

get_balance() {
  check_config

  local resp
  resp=$(api_call "GET" "/api/v1/credits" "")

  local balance reserved available purchased used
  balance=$(json_num "$resp" "balance")
  reserved=$(json_num "$resp" "reservedBalance")
  available=$(json_num "$resp" "availableBalance")
  purchased=$(json_num "$resp" "totalPurchased")
  used=$(json_num "$resp" "totalUsed")

  success "💰 积分余额"
  info "   当前余额:   ${balance:-0}"
  info "   冻结余额:   ${reserved:-0}"
  info "   可用余额:   ${available:-${balance:-0}}"
  info "   已购买:     ${purchased:-0}"
  info "   已使用:     ${used:-0}"
}

cmd_history() {
  local limit="${1:-10}"
  check_config

  info "📋 获取转写历史..."
  local resp
  resp=$(api_call "GET" "/api/v1/history" "")

  echo ""
  info "显示最近 ${limit} 条（精简展示）："
  echo ""

  echo "$resp" | grep -o '{"id":"[^"]*"[^}]*}' | head -n "$limit" | while IFS= read -r row; do
    local status input created
    status=$(json_str "$row" "status")
    input=$(json_str "$row" "input")
    created=$(json_str "$row" "created_at")

    local mark="…"
    [ "$status" = "completed" ] && mark="${GREEN}✓${NC}"
    [ "$status" = "failed" ] && mark="${RED}✗${NC}"

    printf "  %b %.36s  %s\n" "$mark" "$input" "$created"
  done
}

show_help() {
cat << EOF2
dycaption-cli v1.0.0

用法:
  dycaption setup                           首次配置（注册或登录）
  dycaption register                        注册新账号
  dycaption login                           登录已有账号
  dycaption transcribe <链接或分享文案> [语言] 提交转写并轮询结果
  dycaption status <taskId>                 查询任务状态
  dycaption balance                         查询积分余额
  dycaption history [数量]                  查询历史（默认 10）
  dycaption help                            显示帮助

首次使用:
  dycaption setup

配置:
  API Key 保存在 ~/.dycaption，也可通过环境变量设置:
  export DY_CAPTION_API_KEY="dy_xxxxx"

环境变量:
  DY_CAPTION_API_URL             API 地址 (默认: https://api.dytext.cn)
  DY_CAPTION_API_KEY             API 密钥（优先级高于配置文件）
  DY_CAPTION_SUPABASE_URL        Supabase URL（注册/登录必需）
  DY_CAPTION_SUPABASE_ANON_KEY   Supabase anon key（注册/登录必需）

示例:
  dycaption setup
  dycaption transcribe "https://v.douyin.com/xxxxx/"
  dycaption transcribe "6.44 复制打开抖音，看看【xxx】 https://v.douyin.com/xxxxx/" zh-CN
  dycaption status 123e4567-e89b-12d3-a456-426614174000
  dycaption balance
  dycaption history 20

主页: https://dytext.cn
EOF2
}

cmd="${1:-}"
shift || true

case "$cmd" in
  setup)
    cmd_setup
    ;;
  register)
    cmd_register
    ;;
  login)
    cmd_login
    ;;
  transcribe|generate)
    cmd_transcribe "$1" "$2"
    ;;
  status)
    cmd_status "$1"
    ;;
  balance|credits)
    get_balance
    ;;
  history)
    cmd_history "$1"
    ;;
  help|-h|--help|"")
    show_help
    ;;
  *)
    cmd_transcribe "$cmd" "$1"
    ;;
esac
